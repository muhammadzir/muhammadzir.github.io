[
{% for post in site.posts %}
{
  "title": "{{ post.title | escape }}",
  "excerpt": "{{ post.excerpt | strip_html | truncate:120 | escape }}",
  "url": "{{ post.url }}",
  "date": "{{ post.date | date: '%d %b %Y' }}",
  "image": "{{ post.image | default: '' }}"
}{% if forloop.last == false %},{% endif %}
{% endfor %}
]
